<UserControl x:Class="TextureMerge.RoundButton"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:TextureMerge"
             mc:Ignorable="d"
             x:Name="root">
    <Grid>
        <Border Style="{StaticResource RoundBlueBorder}" Padding="8,2,8,2">
            <Label Content="{Binding Text, ElementName=root}" Foreground="White" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Padding="0,0,0,0"/>
        </Border>
    </Grid>
</UserControl>
